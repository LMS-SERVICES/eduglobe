# Point this to your LMS user portal (e.g. where students login and access courses).
# Example: https://lms.eduglobe.com or http://localhost:3001
NEXT_PUBLIC_LMS_PORTAL_URL=/lms

# --- App + Docker (copy to .env and fill in) ---
#
# Neon (recommended pooled URL for the app — copy from Neon Dashboard → Connection string → Prisma):
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"
# For `prisma migrate` / `db push`, Neon also gives a direct (non-pooler) URL — use that in terminal when prompted, or set:
# DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require"
# (If you add directUrl to schema.prisma, both vars are required for migrations.)
#
# Generic Postgres:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require"
# NEXTAUTH_SECRET="generate with: openssl rand -base64 32"
# NEXTAUTH_URL="http://localhost:3000"
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
